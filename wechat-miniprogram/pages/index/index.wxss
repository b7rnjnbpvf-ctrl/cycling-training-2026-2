.hero{position:relative;overflow:hidden;border:1rpx solid rgba(255,255,255,.12);border-radius:40rpx;min-height:720rpx;padding:48rpx 34rpx 28rpx;background:linear-gradient(135deg,rgba(20,36,50,.95),rgba(16,27,37,.72));box-shadow:0 28rpx 80rpx rgba(0,0,0,.28)}.hero:after{content:"";position:absolute;width:330rpx;height:330rpx;border:12rpx solid rgba(255,255,255,.13);border-radius:50%;right:-90rpx;bottom:80rpx}.kicker{display:inline-block;color:#c7fff0;background:rgba(97,242,194,.1);border:1rpx solid rgba(97,242,194,.25);font-size:24rpx;padding:14rpx 18rpx;border-radius:999rpx}.hero-title{position:relative;z-index:1;font-size:60rpx;line-height:1.08;font-weight:900;margin:30rpx 0 20rpx;letter-spacing:-2rpx}.hero-desc{position:relative;z-index:1;color:#9eb3c4;font-size:28rpx;line-height:1.8}.hero-actions{display:grid;grid-template-columns:1fr 1fr;gap:18rpx;margin-top:36rpx}.hero-actions button{margin:0;border-radius:24rpx;font-weight:800;font-size:28rpx}.primary{background:linear-gradient(135deg,#61f2c2,#55a7ff);color:#031018}.ghost{background:rgba(255,255,255,.06);color:#eef7ff;border:1rpx solid rgba(255,255,255,.12)}.stats{display:grid;grid-template-columns:repeat(3,1fr);gap:14rpx;margin-top:38rpx}.stat{padding:22rpx 16rpx;border-radius:26rpx;background:rgba(255,255,255,.06);border:1rpx solid rgba(255,255,255,.12)}.stat text{display:block;color:#9eb3c4;font-size:22rpx}.stat-main{color:#eef7ff!important;font-size:30rpx!important;font-weight:900;margin-bottom:4rpx}.section{padding-top:34rpx}.section-head{display:flex;justify-content:space-between;align-items:flex-end;margin:0 2rpx 18rpx}.section-title{font-size:38rpx;font-weight:900}.section-sub{font-size:22rpx;color:#9eb3c4}.card{border:1rpx solid rgba(255,255,255,.12);background:linear-gradient(180deg,rgba(20,36,50,.92),rgba(13,24,34,.92));border-radius:32rpx;overflow:hidden;box-shadow:0 18rpx 48rpx rgba(0,0,0,.18);margin-bottom:22rpx}.cover{height:210rpx;position:relative;background:linear-gradient(135deg,rgba(85,167,255,.35),rgba(97,242,194,.16)),linear-gradient(45deg,#162635,#0c1822)}.cover.photo{background:linear-gradient(rgba(7,16,24,.1),rgba(7,16,24,.72)),linear-gradient(135deg,#17304a,#0c1822 55%,#0a513f)}.cover.route{background:linear-gradient(rgba(7,16,24,.05),rgba(7,16,24,.74)),repeating-linear-gradient(0deg,rgba(255,255,255,.08) 0 1rpx,transparent 1rpx 54rpx),repeating-linear-gradient(90deg,rgba(255,255,255,.08) 0 1rpx,transparent 1rpx 68rpx),linear-gradient(135deg,#072034,#114035)}.cover.know{background:linear-gradient(rgba(7,16,24,.05),rgba(7,16,24,.78)),linear-gradient(135deg,#12263a,#10251f)}.tag{position:absolute;left:22rpx;top:22rpx;font-size:22rpx;padding:12rpx 18rpx;border-radius:999rpx;background:rgba(7,16,24,.62);border:1rpx solid rgba(255,255,255,.18);color:#eef7ff}.card-body{padding:26rpx}.card-title{font-size:34rpx;font-weight:900;margin-bottom:12rpx}.card-desc{color:#9eb3c4;font-size:26rpx;line-height:1.65}.chips{display:flex;gap:10rpx;flex-wrap:wrap;margin-top:20rpx}.chip{font-size:22rpx;color:#d9f4ff;background:rgba(255,255,255,.06);border:1rpx solid rgba(255,255,255,.12);border-radius:999rpx;padding:10rpx 16rpx}.link-btn{margin-top:22rpx;border-radius:24rpx;background:rgba(97,242,194,.1);border:1rpx solid rgba(97,242,194,.22);color:#d9fff5;font-weight:900;font-size:26rpx;text-align:left}.feature{display:grid;grid-template-columns:78rpx 1fr;gap:18rpx;padding:24rpx;border-radius:30rpx;background:rgba(255,255,255,.055);border:1rpx solid rgba(255,255,255,.12);margin-bottom:18rpx}.icon{width:78rpx;height:78rpx;border-radius:24rpx;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,rgba(97,242,194,.22),rgba(85,167,255,.18));font-size:38rpx}.feature-title{font-size:30rpx;font-weight:900;margin-bottom:8rpx}.feature-desc{color:#9eb3c4;font-size:24rpx;line-height:1.55}.edit-box{border:1rpx dashed rgba(97,242,194,.35);background:rgba(97,242,194,.07);border-radius:30rpx;padding:24rpx;color:#d9fff5;font-size:24rpx;line-height:1.75;margin-top:30rpx}
